generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
    id          Int           @id
    name        String
    email       String        @unique
    password    String
    created_at  DateTime      @default(now())
    updated_at  DateTime      @default(now()) @updatedAt
    is_admin    Boolean       @default(false)
    role        String        @default("checker")
    Document    Document[]
    Product     Product[]
    Session     Session[]
    OdooSession OdooSession[]
}

model OdooSession {
    id           String    @id @default(cuid())
    user_id      Int
    email        String
    session_data Json
    expires_at   DateTime?
    is_active    Boolean   @default(true)
    created_at   DateTime  @default(now())
    updated_at   DateTime  @updatedAt
    user         User      @relation(fields: [user_id], references: [id])

    @@index([user_id])
    @@index([expires_at])
    @@map("odoo_sessions")
}

model Session {
    id             Int          @id @default(autoincrement())
    name           String
    created_at     DateTime     @default(now())
    state          SessionState @default(DRAFT)
    warehouse_id   Int?
    warehouse_name String?
    inventory_id   Int?
    user_id        Int?
    products       Product[]
    user           User?        @relation(fields: [user_id], references: [id])

    @@index([user_id])
    @@index([created_at])
}

model Document {
    id             Int           @id @default(autoincrement())
    inventory_id   Int?
    name           String?
    created_at     DateTime      @default(now())
    warehouse_id   Int?
    warehouse_name String?
    state          DocumentState @default(POST)
    userId         Int?
    user           User?         @relation(fields: [userId], references: [id])
    products       Product[]

    @@index([created_at])
}

model Product {
    id               Int          @id @default(autoincrement())
    product_id       Int?
    barcode          String
    name             String?
    created_at       DateTime     @default(now())
    quantity         Float        @default(1)
    uom_id           Int?
    uom_name         String?
    location_id      Int?
    location_name    String?
    res_partner_id   Int?
    res_partner_name String?
    state            ProductState @default(DRAFT)
    session_id       Int?
    userId           Int?
    document_id      Int?
    Document         Document?    @relation(fields: [document_id], references: [id])
    session          Session?     @relation(fields: [session_id], references: [id], onDelete: Restrict)
    uom              Uom?         @relation(fields: [uom_id], references: [id])
    User             User?        @relation(fields: [userId], references: [id])

    @@index([state])
    @@index([barcode])
    @@index([session_id])
    @@index([created_at])
    @@index([product_id])
}

model UomCategory {
    id   Int    @id
    name String
    uoms Uom[]

    @@map("uom_categories")
}

model Uom {
    id          Int         @id
    name        String
    category_id Int
    uom_type    String
    factor_inv  Float?
    factor      Float?
    products    Product[]
    category    UomCategory @relation(fields: [category_id], references: [id])

    @@index([category_id])
    @@map("uoms")
}

model VerificationResult {
    id                   Int      @id @default(autoincrement())
    odoo_line_id         Int
    product_qty          Float
    location_id          Int
    verifier_id          Int
    created_at           DateTime @default(now())
    updated_at           DateTime @updatedAt
    note                 String?
    odoo_verification_id Int?

    @@map("verification_results")
}

enum SessionState {
    DRAFT
    CONFIRMED
    POST
    DONE
}

enum ProductState {
    DRAFT
    CONFIRMED
    POST
    DONE
}

enum DocumentState {
    POST
    DONE
}
